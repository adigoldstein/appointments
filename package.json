    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "nx": "22.7.3",
    "playwright": "^1.61.1",
    "prettier": "~3.6.2",
    "storybook": "^10.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",

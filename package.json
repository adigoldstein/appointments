{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --targets=serve --projects=frontend,backend --parallel=2",
    "dev": "nx run-many --targets=serve --projects=frontend,backend --parallel=2 --output-style=stream",
    "start:frontend": "nx serve frontend",
    "start:backend": "nx serve backend",
    "build": "nx run-many --targets=build --all",
    "lint": "nx run-many --targets=lint --all",
    "test": "nx run-many --targets=test --all",
    "typeorm": "set TS_NODE_PROJECT=apps/backend/tsconfig.app.json&& node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d apps/backend/src/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate apps/backend/src/database/migrations/InitialAuthSchema",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "storybook": "nx run frontend:storybook",
    "build:storybook": "nx run frontend:build-storybook"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.0",
    "@angular/cdk": "~21.2.0",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/material": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@fontsource/rubik": "^5.2.8",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.0",
    "typeorm": "^1.0.0"
  },
